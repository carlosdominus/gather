{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile containing authentication details, custom avatar, role, and workspace properties",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "name": { "type": "string" },
        "role": { "type": "string" },
        "color": { "type": "string" },
        "emoji": { "type": "string" },
        "photoUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "name", "role", "color", "emoji"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Stores user profiles in the Virtual Office application"
    }
  }
}
