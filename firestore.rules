rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global safety net: deny all by default
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper: Checks if the user is authenticated
    function isSignedIn() {
      return request.auth != null;
    }

    // Helper: Validates a User profile document shape
    function isValidUser(data) {
      return data.uid == request.auth.uid
        && data.email is string && data.email.size() <= 256
        && data.name is string && data.name.size() > 0 && data.name.size() <= 100
        && data.role is string && data.role.size() <= 100
        && data.color is string && data.color.size() <= 30
        && data.emoji is string && data.emoji.size() <= 20
        && (!('photoUrl' in data) || (data.photoUrl is string && data.photoUrl.size() <= 1200000));
    }

    // Match block for users collection
    match /users/{userId} {
      allow get: if isSignedIn() && userId == request.auth.uid;
      allow list: if isSignedIn();

      // Create: User must be creating their own profile with correct schema
      allow create: if isSignedIn() 
        && userId == request.auth.uid 
        && isValidUser(request.resource.data)
        && request.resource.data.createdAt == request.time
        && request.resource.data.updatedAt == request.time;

      // Update: User can only update their own profile, preserving createdAt
      allow update: if isSignedIn() 
        && userId == request.auth.uid 
        && isValidUser(request.resource.data)
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.updatedAt == request.time;

      allow delete: if false;
    }
  }
}
